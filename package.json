{
  "name": "discord-bot",
  "private": true,
  "workspaces": ["packages/*", "api-server"],
  "scripts": {
    "build": "npm run build -w packages/db && npm run build -w api-server",
    "start": "node api-server/dist/index.js",
    "dev": "tsx api-server/src/index.ts",
    "db:push": "drizzle-kit push --config=packages/db/drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
